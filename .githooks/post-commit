#!/bin/bash
# Post-commit hook to auto-update LeetCode statistics
# Triggers when commit message contains "Add leetcode" (case insensitive)

# Lock file to prevent infinite recursion during amend
LOCK_FILE=".git/post-commit-running"

# Check if we're already running (prevents infinite loop from amend)
if [ -f "$LOCK_FILE" ]; then
  exit 0
fi

# Get the commit message
commit_msg=$(git log -1 --pretty=%B)

# Check if message contains "Add leetcode" (case insensitive)
if echo "$commit_msg" | grep -iq "Add leetcode"; then
  echo "Detected LeetCode addition, updating statistics..."

  # Run the stats generator
  if command -v uv &>/dev/null; then
    uv run --package lc-stats lc-stats

    # Check if files were modified
    if git diff --quiet assets/stats/*.png README.md README_zh.md 2>/dev/null; then
      echo "No changes to statistics."
    else
      echo "Amending commit with updated statistics..."
      # Create lock file before amend to prevent recursion
      touch "$LOCK_FILE"
      git add assets/stats/* README.md README_zh.md 2>/dev/null
      git commit --amend --no-edit
      # Remove lock file after amend completes
      rm -f "$LOCK_FILE"
      echo "Statistics updated successfully!"
    fi
  else
    echo "Warning: uv not found. Please run 'uv run --package lc-stats lc-stats' manually."
  fi
fi
